{% extends 'base.html.twig' %}

{% block title %}🎬 MovieCatalog - Admin Control{% endblock %}

{% block body %}
<style>
    /* Լռելյայն փոփոխականներ Մութ թեմայի համար (Dark Mode) */
    :root {
        --bg-color: #141414;
        --card-bg: #1f1f1f;
        --text-color: #ffffff;
        --text-muted: #b3b3b3;
        --navbar-bg: #000000;
        --input-bg: #2b2b2b;
        --input-border: #333;
        --modal-bg: #1f1f1f;
        --modal-movie-bg: #181818;
        --hero-gradient: linear-gradient(180deg, rgba(229, 9, 20, 0.15) 0%, rgba(20, 20, 20, 0) 100%);
    }

    /* Փոփոխականներ Բաց թեմայի համար (Light Mode) */
    [data-theme="light"] {
        --bg-color: #f5f5f7;
        --card-bg: #ffffff;
        --text-color: #1d1d1f;
        --text-muted: #6e6e73;
        --navbar-bg: #ffffff;
        --input-bg: #e8e8ed;
        --input-border: #d2d2d7;
        --modal-bg: #ffffff;
        --modal-movie-bg: #f5f5f7;
        --hero-gradient: linear-gradient(180deg, rgba(229, 9, 20, 0.08) 0%, rgba(245, 245, 247, 0) 100%);
    }

    body { 
        background-color: var(--bg-color); 
        color: var(--text-color); 
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
        margin: 0; 
        transition: background-color 0.3s, color 0.3s;
    }
    
    /* Վերևի Նավիգացիոն Պանել (Header) */
    .navbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: var(--navbar-bg);
        padding: 15px 40px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        position: sticky;
        top: 0;
        z-index: 100;
        transition: background-color 0.3s;
    }
    .navbar-brand {
        color: #E50914;
        font-size: 1.8rem;
        font-weight: bold;
        text-decoration: none;
    }
    .nav-links {
        display: flex;
        gap: 20px;
        align-items: center;
    }
    .nav-link-item {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 500;
        transition: color 0.2s;
        cursor: pointer;
    }
    .nav-link-item:hover, .nav-link-item.active {
        color: var(--text-color);
    }
    .nav-controls {
        display: flex;
        align-items: center;
        gap: 15px;
    }
    
    /* Լեզվի Ընտրության Դաշտ */
    .lang-select {
        background-color: var(--input-bg);
        color: var(--text-color);
        border: 1px solid var(--input-border);
        padding: 8px 12px;
        font-size: 0.95rem;
        border-radius: 4px;
        cursor: pointer;
        outline: none;
        transition: border-color 0.2s, background-color 0.3s, color 0.3s;
    }
    .lang-select:focus {
        border-color: #E50914;
    }

    /* Թեմայի Փոփոխման Կոճակ */
    .theme-toggle-btn {
        background: var(--input-bg);
        border: 1px solid var(--input-border);
        color: var(--text-color);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        transition: background-color 0.3s, transform 0.2s;
    }
    .theme-toggle-btn:hover {
        transform: scale(1.1);
    }

    .nav-btn {
        background-color: transparent;
        color: var(--text-color);
        border: 2px solid var(--text-color);
        padding: 8px 20px;
        font-size: 1rem;
        font-weight: bold;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s;
    }
    .nav-btn:hover {
        background-color: var(--text-color);
        color: var(--bg-color);
    }
    .login-btn {
        background-color: #E50914;
        color: white;
        border: none;
        padding: 8px 20px;
        font-size: 1rem;
        font-weight: bold;
        border-radius: 4px;
        cursor: pointer;
        transition: background-color 0.2s, transform 0.1s;
    }
    .login-btn:hover {
        background-color: #b80710;
        transform: scale(1.05);
    }

    /* Հիմնական Կոնտենտ */
    .container { max-width: 1200px; margin: 40px auto; padding: 20px; }
    
    /* ԳԼԽԱՎՈՐ ԷՋԻ ՈՂՋՈՒՅՆԻ ԲԱԺԻՆ */
    .hero-section {
        text-align: center;
        padding: 60px 20px;
        background: var(--hero-gradient);
        border-radius: 12px;
        margin-bottom: 40px;
        transition: background 0.3s;
    }
    .hero-section h1 { font-size: 3.5rem; color: var(--text-color); margin-bottom: 15px; }
    .hero-section p { font-size: 1.3rem; color: var(--text-muted); max-width: 600px; margin: 0 auto 30px auto; }
    
    /* ՈՐՈՆՄԱՆ ԴԱՇՏ ԵՎ ԺԱՆՐԵՐԻ ՑՈՒՑԱԿ */
    .search-wrapper {
        max-width: 600px;
        margin: 0 auto;
        position: relative;
    }
    .search-input {
        width: 100%;
        padding: 16px 20px 16px 50px;
        font-size: 1.1rem;
        background-color: var(--input-bg);
        border: 2px solid transparent;
        border-radius: 50px;
        color: var(--text-color);
        box-sizing: border-box;
        transition: all 0.3s;
    }
    .search-input:focus {
        outline: none;
        border-color: #E50914;
        background-color: var(--card-bg);
        box-shadow: 0 0 15px rgba(229, 9, 20, 0.3);
    }
    .search-icon {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.2rem;
        color: var(--text-muted);
    }

    /* Ժանրերի բացվող ցուցակը */
    .genres-dropdown {
        position: absolute;
        top: 110%;
        left: 0;
        width: 100%;
        background-color: var(--card-bg);
        border: 1px solid var(--input-border);
        border-radius: 8px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.2);
        display: none;
        z-index: 10;
        padding: 15px;
        box-sizing: border-box;
    }
    .genres-dropdown.show {
        display: block;
    }
    .genres-dropdown h4 {
        margin: 0 0 10px 5px;
        color: #E50914;
        font-size: 1rem;
        text-align: left;
    }
    .genres-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 10px;
    }
    .genre-badge-btn {
        background-color: var(--input-bg);
        color: var(--text-color);
        border: none;
        padding: 8px 12px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.2s;
        text-align: center;
    }
    .genre-badge-btn:hover {
        background-color: #E50914;
        color: white;
    }

    /* Ֆիլմերի Ցանց */
    .section-title {
        font-size: 2rem;
        margin-bottom: 25px;
        border-left: 5px solid #E50914;
        padding-left: 15px;
    }
    .movie-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px; }
    .movie-card { 
        background: var(--card-bg); 
        border-radius: 10px; 
        overflow: hidden; 
        box-shadow: 0 4px 8px rgba(0,0,0,0.15); 
        transition: transform 0.2s, box-shadow 0.2s, background-color 0.3s; 
        display: flex; 
        flex-direction: column; 
        justify-content: space-between; 
        cursor: pointer;
    }
    .movie-card:hover { 
        transform: scale(1.03); 
        box-shadow: 0 8px 16px rgba(229, 9, 20, 0.2); 
    }
    .movie-img { width: 100%; height: 350px; object-fit: cover; object-position: center; }
    .movie-content { padding: 15px; display: flex; flex-direction: column; flex-grow: 1; justify-content: space-between; }
    .movie-card h3 { margin-top: 0; color: var(--text-color); font-size: 1.15rem; line-height: 1.3; }
    .movie-card p { color: var(--text-muted); font-size: 0.85rem; line-height: 1.4; flex-grow: 1; margin: 10px 0; }
    .genre { display: inline-block; background: #E50914; color: white; padding: 5px 10px; border-radius: 4px; font-size: 10px; font-weight: bold; align-self: flex-start; }

    /* Չգտնված ֆիլմի հաղորդագրություն */
    .no-results {
        display: none;
        text-align: center;
        padding: 40px;
        font-size: 1.4rem;
        color: var(--text-muted);
        background-color: var(--card-bg);
        border-radius: 10px;
        border: 1px dashed var(--input-border);
        grid-column: 1 / -1;
    }

    /* Էջերի Ցուցադրություն */
    .page-section { display: none; }
    .page-section.active { display: block; }

    /* Admin Panel */
    .admin-container {
        max-width: 1100px;
        margin: 50px auto;
        padding: 30px;
        background-color: var(--card-bg);
        border-radius: 10px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        transition: background-color 0.3s;
    }
    .admin-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid var(--input-border);
        padding-bottom: 20px;
        margin-bottom: 30px;
    }
    .admin-header h2 { margin: 0; color: #E50914; }
    
    .admin-form-section {
        margin-bottom: 40px;
        padding-bottom: 25px;
        border-bottom: 1px dashed var(--input-border);
    }
    .admin-form-section h3 {
        color: var(--text-color);
        margin-bottom: 15px;
        font-size: 1.3rem;
    }

    .admin-form {
        display: flex;
        flex-direction: column;
        gap: 15px;
        background-color: var(--bg-color);
        padding: 20px;
        border-radius: 8px;
        transition: background-color 0.3s;
    }
    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
    }
    .admin-form .form-group { margin-bottom: 0; }
    .admin-form label { display: block; margin-bottom: 8px; color: var(--text-muted); font-size: 0.9rem; }
    .admin-form input, .admin-form select, .admin-form textarea {
        width: 100%; padding: 10px;
        border: 1px solid var(--input-border); border-radius: 4px;
        background-color: var(--input-bg); color: var(--text-color);
        box-sizing: border-box;
        font-family: inherit;
        transition: background-color 0.3s, color 0.3s;
    }
    .admin-form input:focus, .admin-form select:focus, .admin-form textarea:focus { border-color: #E50914; outline: none; }
    
    .add-user-btn {
        background-color: #E50914; color: white; border: none;
        padding: 11px 25px; font-size: 1rem; font-weight: bold;
        border-radius: 4px; cursor: pointer; transition: background-color 0.2s;
        align-self: flex-start;
    }
    .add-user-btn:hover { background-color: #b80710; }

    .users-table { width: 100%; border-collapse: collapse; margin-top: 15px; margin-bottom: 30px; }
    .users-table th, .users-table td { padding: 12px 15px; text-align: left; border-bottom: 1px solid var(--input-border); }
    .users-table th { background-color: var(--bg-color); color: #E50914; font-weight: bold; transition: background-color 0.3s; }
    .users-table tr:hover { background-color: var(--input-bg); }
    
    .delete-btn {
        background-color: #e50914; color: white; border: none;
        padding: 6px 12px; border-radius: 4px; cursor: pointer;
        font-size: 0.85rem; transition: background-color 0.2s;
    }
    .delete-btn:hover { background-color: #b80710; }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background-color: rgba(0, 0, 0, 0.7);
        display: none; justify-content: center; align-items: center;
        z-index: 1000;
    }
    .modal-content {
        background-color: var(--modal-bg); padding: 40px; border-radius: 8px;
        width: 100%; max-width: 400px; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        position: relative;
        transition: background-color 0.3s;
    }
    .close-btn { position: absolute; top: 15px; right: 20px; font-size: 1.5rem; color: var(--text-muted); cursor: pointer; }
    .close-btn:hover { color: var(--text-color); }
    .modal-content h2 { margin-top: 0; color: var(--text-color); margin-bottom: 25px; text-align: center; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; margin-bottom: 8px; color: var(--text-muted); font-size: 0.9rem; }
    .form-group input {
        width: 100%; padding: 12px; border: 1px solid var(--input-border); border-radius: 4px;
        background-color: var(--input-bg); color: var(--text-color); font-size: 1rem; box-sizing: border-box;
        transition: background-color 0.3s, color 0.3s;
    }
    .form-group input:focus { outline: none; border-color: #E50914; }
    .submit-btn {
        width: 100%; padding: 12px; background-color: #E50914; color: white;
        border: none; border-radius: 4px; font-size: 1.1rem; font-weight: bold;
        cursor: pointer; transition: background-color 0.2s;
    }
    .submit-btn:hover { background-color: #b80710; }

    /* Movie details Modal */
    .movie-modal-overlay {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100%;
        background-color: rgba(0, 0, 0, 0.8);
        display: none; justify-content: center; align-items: center;
        z-index: 1001; padding: 20px; box-sizing: border-box;
    }
    .movie-modal-content {
        background-color: var(--modal-movie-bg); border-radius: 12px;
        width: 100%; max-width: 850px; overflow: hidden;
        box-shadow: 0 0 30px rgba(229, 9, 20, 0.2);
        position: relative; display: flex; flex-direction: row;
        transition: background-color 0.3s;
    }
    @media (max-width: 768px) {
        .movie-modal-content { flex-direction: column; }
        .movie-modal-img { height: 250px !important; width: 100% !important; }
    }
    .movie-modal-img { width: 40%; height: 520px; object-fit: cover; }
    .movie-modal-details {
        padding: 35px; width: 60%;
        display: flex; flex-direction: column;
        justify-content: center; box-sizing: border-box;
    }
    .movie-modal-details h2 { margin-top: 0; font-size: 1.8rem; color: var(--text-color); margin-bottom: 10px; }
    .movie-modal-details .modal-genre { align-self: flex-start; margin-bottom: 15px; }
    .movie-modal-details p { color: var(--text-color); opacity: 0.9; font-size: 0.95rem; line-height: 1.5; margin-bottom: 30px; }
    
    .movie-modal-close {
        position: absolute; top: 15px; right: 20px;
        font-size: 2rem; color: #fff; cursor: pointer; z-index: 10;
        background-color: rgba(0,0,0,0.5); width: 40px; height: 40px;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        transition: background-color 0.2s;
    }
    .movie-modal-close:hover { background-color: #E50914; }
</style>

<header class="navbar">
    <a href="#" class="navbar-brand" id="logoLink">🎬 MovieCatalog</a>
    <nav class="nav-links">
        <span class="nav-link-item active" id="homeNav" data-translate="home_nav">Գլխավոր</span>
        <span class="nav-link-item" id="filmsNav" data-translate="films_nav">Ֆիլմեր</span>
    </nav>
    <div class="nav-controls">
        <select id="langSelect" class="lang-select">
            <option value="hy">Հայերեն</option>
            <option value="en">English</option>
            <option value="ru">Русский</option>
        </select>

        <button id="themeToggleBtn" class="theme-toggle-btn" title="Toggle Theme">
            🌙
        </button>
        
        <button class="nav-btn" id="adminPageBtn" data-translate="admin_btn">Admin Panel</button>
        <button class="login-btn" id="openModalBtn" data-translate="login_btn">Log In</button>
    </div>
</header>

<div class="modal-overlay" id="modalOverlay">
    <div class="modal-content">
        <span class="close-btn" id="closeModalBtn">&times;</span>
        <h2 id="modalTitle" data-translate="modal_title">Մուտք / Գրանցում</h2>
        <form id="loginForm">
            <div class="form-group">
                <label for="email" data-translate="email_label">Էլ. հասցե</label>
                <input type="email" id="email" placeholder="example@mail.com" required>
            </div>
            <div class="form-group">
                <label for="password" data-translate="password_label">Գաղտնաբառ</label>
                <input type="password" id="password" placeholder="••••••••" required>
            </div>
            <button type="submit" class="submit-btn" id="modalSubmitBtn" data-translate="login_submit">Մուտք Գործել</button>
        </form>
    </div>
</div>

<div class="movie-modal-overlay" id="movieModalOverlay">
    <div class="movie-modal-content">
        <span class="movie-modal-close" id="closeMovieModalBtn">&times;</span>
        <img class="movie-modal-img" id="modalMovieImg" src="" alt="">
        <div class="movie-modal-details">
            <h2 id="modalMovieTitle">Ֆիլմի վերնագիր</h2>
            <span class="genre modal-genre" id="modalMovieGenre">Ժանր</span>
            <p id="modalMovieDesc">Ֆիլմի նկարագրությունը:</p>
            
            <a href="#" target="_blank" class="submit-btn" id="watchTrailerBtn" style="text-align: center; text-decoration: none; display: block;" data-translate="watch_trailer">🎬 Դիտել Թրեյլերը YouTube-ում</a>
        </div>
    </div>
</div>

<div id="homePage" class="container page-section active">
    <div class="hero-section">
        <h1 data-translate="hero_title">Բարի գալուստ MovieCatalog</h1>
        <p data-translate="hero_subtitle">Փնտրիր և բացահայտիր քո սիրելի ֆիլմերն ու դրանց պաշտոնական թրեյլերները մեկ վայրում։</p>
        
        <div class="search-wrapper" id="searchContainer">
            <span class="search-icon">🔍</span>
            <input type="text" id="movieSearch" class="search-input" placeholder="Մուտքագրեք անվանումը և սեղմեք Enter..." autocomplete="off">
            
            <div class="genres-dropdown" id="genresDropdown">
                <h4 data-translate="dropdown_title">🎭 Ընտրեք Ժանրը</h4>
                <div class="genres-grid">
                    <button class="genre-badge-btn" data-genre-key="scifi" data-translate="genre_scifi">Գիտ. Ֆանտաստիկա</button>
                    <button class="genre-badge-btn" data-genre-key="drama" data-translate="genre_drama">Դրամա</button>
                    <button class="genre-badge-btn" data-genre-key="action" data-translate="genre_action">Մարտաֆիլմ</button>
                    <button class="genre-badge-btn" data-genre-key="thriller" data-translate="genre_thriller">Դետեկտիվ</button>
                    <button class="genre-badge-btn" data-genre-key="comedy" data-translate="genre_comedy">Կատակերգություն</button>
                    <button class="genre-badge-btn" data-genre-key="fantasy" data-translate="genre_fantasy">Ֆենտեզի</button>
                    <button class="genre-badge-btn" data-genre-key="animation" data-translate="genre_animation">Անիմացիա</button>
                    <button class="genre-badge-btn" data-genre-key="all" data-translate="genre_all">Բոլորը</button>
                </div>
            </div>
        </div>
    </div>

    <h2 class="section-title" data-translate="trending_title">Թրենդային Ֆիլմեր</h2>
    <div class="movie-grid" id="featuredMoviesGrid">
        </div>
</div>

<div id="filmsPage" class="container page-section">
    <h2 class="section-title" data-translate="all_movies_title">Բոլոր Ֆիլմերը</h2>
    
    <div class="movie-grid" id="moviesCatalogGrid">
        </div>
    
    <div id="noResultsMessage" class="no-results" data-translate="no_movie_found">
        Այդպիսի ֆիլմ գոյություն չունի
    </div>
</div>

<div id="adminPage" class="page-section">
    <div class="admin-container">
        <div class="admin-header">
            <h2 data-translate="admin_title_header">⚙️ Օգտատերերի և Ֆիլմերի Կառավարման Վահանակ</h2>
            <button class="nav-btn" id="backToHomeBtn" data-translate="back_home">← Հետ Դեպի Գլխավոր</button>
        </div>

        <div class="admin-form-section">
            <h3 data-translate="admin_add_movie_section">🎬 Ավելացնել Նոր Ֆիլմ</h3>
            <form class="admin-form" id="addMovieForm">
                <div class="form-row">
                    <div class="form-group">
                        <label for="movieImgUrl" data-translate="admin_movie_img">Նկարի հղում (URL)</label>
                        <input type="url" id="movieImgUrl" placeholder="https://..." required>
                    </div>
                    <div class="form-group">
                        <label for="movieGenreKey" data-translate="admin_movie_genre">Ժանրի տեսակ</label>
                        <select id="movieGenreKey" required>

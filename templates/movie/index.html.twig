            translations: {
                hy: { title: "Գրավիտացիա", genre: "Գիտական Ֆանտաստիկա", shortDesc: "Երկու տիեզերագնացներ պայքարում են գոյատևելու համար տիեզերքի դատարկության մեջ։", desc: "Բժիշկ Ռայան Սթոունը և վետերան տիեզերագնաց Մեթ Կովալսկին հայտնվում են բաց տիեզերքում աղետից հետո:" },
                en: { title: "Gravity", genre: "Sci-Fi", shortDesc: "Two astronauts work together to survive after an accident.", desc: "A medical engineer on her first shuttle mission and a veteran astronaut find themselves drifting in the deep dark of space." },
                ru: { title: "Гравитация", genre: "Научная Фантастика", shortDesc: "Два астронавта борются за жизнь в открытом космосе после катастрофы.", desc: "Доктор Райан Стоун и опытный астронавт Мэтт Ковальски оказываются совершенно одни в открытом космосе после крушения их шаттла." }
            }
        },
        {
            id: 20,
            img: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSI16lz05ri8uTJnICbwEjY-ZnnPlDsWTRXTcPuqbAu2g&s",
            genreKey: "animation",
            trailerId: "2zL8BYUz70Q",
            translations: {
                hy: { title: "Կայծակնային պատմություն", genre: "Անիմացիա", shortDesc: "Երիտասարդ մրցարշավային մեքենան հասկանում է, որ կյանքում կարևորը ոչ միայն հաղթանակն է։", desc: "ՄակՔուինը մոլորվում է գավառական Ռադիատոր Սփրինգս քաղաքում, որտեղ գտնում է իսկական ընկերներ և սեր:" },
                en: { title: "Cars", genre: "Animation", shortDesc: "A hotshot racecar named Lightning McQueen gets lost in a small town.", desc: "On the way to the biggest race of his life, McQueen gets stranded in Radiator Springs and learns what's truly important." },
                ru: { title: "Тачки", genre: "Анимация", shortDesc: "Молодая гоночная машина Маккуин оказывается в забытом богом городке.", desc: "Неукротимый гоночный болид Молния Маккуин из-за случайности попадает в захолустный городок Радиатор-Спрингс." }
            }
        }
    ];

    // --- ԼՈԿԱԼ ՊԱՀՈՑԻ ԿԱՐԳԱՎՈՐՈՒՄՆԵՐ ---
    if (!localStorage.getItem('movies')) {
        localStorage.setItem('movies', JSON.stringify(defaultMoviesData));
    } else {
        localStorage.setItem('movies', JSON.stringify(defaultMoviesData));
    }
    let movies = JSON.parse(localStorage.getItem('movies'));

    const defaultUsers = [
        { id: 1, username: "Աննա Սարգսյան", email: "anna@mail.ru" },
        { id: 2, username: "Դավիթ Գրիգորյան", email: "david99@gmail.com" },
        { id: 3, username: "Մարիամ Ավետիսյան", email: "mariam.avet@yandex.ru" }
    ];
    if (!localStorage.getItem('users')) {
        localStorage.setItem('users', JSON.stringify(defaultUsers));
    }
    let users = JSON.parse(localStorage.getItem('users'));

    let currentLang = localStorage.getItem('lang') || 'hy';
    let currentTheme = localStorage.getItem('theme') || 'dark';

    // --- DOM ՏԱՐՐԵՐ ---
    const homePage = document.getElementById('homePage');
    const filmsPage = document.getElementById('filmsPage');
    const adminPage = document.getElementById('adminPage');
    const homeNav = document.getElementById('homeNav');
    const filmsNav = document.getElementById('filmsNav');
    const adminPageBtn = document.getElementById('adminPageBtn');
    const backToHomeBtn = document.getElementById('backToHomeBtn');
    const logoLink = document.getElementById('logoLink');
    const openModalBtn = document.getElementById('openModalBtn');
    const closeModalBtn = document.getElementById('closeModalBtn');
    const modalOverlay = document.getElementById('modalOverlay');
    const loginForm = document.getElementById('loginForm');
    const themeToggleBtn = document.getElementById('themeToggleBtn');
    const langSelect = document.getElementById('langSelect');
    
    const movieSearch = document.getElementById('movieSearch');
    const genresDropdown = document.getElementById('genresDropdown');
    const searchContainer = document.getElementById('searchContainer');
    const featuredMoviesGrid = document.getElementById('featuredMoviesGrid');
    const moviesCatalogGrid = document.getElementById('moviesCatalogGrid');
    const noResultsMessage = document.getElementById('noResultsMessage');

    const usersTableBody = document.getElementById('usersTableBody');
    const adminMoviesTableBody = document.getElementById('adminMoviesTableBody');
    const addUserForm = document.getElementById('addUserForm');
    const addMovieForm = document.getElementById('addMovieForm');

    const movieModalOverlay = document.getElementById('movieModalOverlay');
    const closeMovieModalBtn = document.getElementById('closeMovieModalBtn');
    const modalMovieImg = document.getElementById('modalMovieImg');
    const modalMovieTitle = document.getElementById('modalMovieTitle');
    const modalMovieGenre = document.getElementById('modalMovieGenre');
    const modalMovieDesc = document.getElementById('modalMovieDesc');
    const watchTrailerBtn = document.getElementById('watchTrailerBtn');

    // --- ԹԵՄԱՅԻ ԿԱՌԱՎԱՐՈՒՄ ---
    function applyTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        themeToggleBtn.innerHTML = theme === 'dark' ? '🌙' : '☀️';
        localStorage.setItem('theme', theme);
    }
    themeToggleBtn.addEventListener('click', () => {
        currentTheme = currentTheme === 'dark' ? 'light' : 'dark';
        applyTheme(currentTheme);
    });

    // --- ԹԱՐԳՄԱՆՈՒԹՅՈՒՆՆԵՐԻ ԿԻՐԱՌՈՒՄ ---
    function applyTranslations(lang) {
        document.querySelectorAll('[data-translate]').forEach(el => {
            const key = el.getAttribute('data-translate');
            if (translations[lang] && translations[lang][key]) {
                if (el.tagName === 'INPUT' && el.hasAttribute('placeholder')) {
                    el.placeholder = translations[lang][key];
                } else {
                    el.textContent = translations[lang][key];
                }
            }
        });
        movieSearch.placeholder = translations[lang].search_placeholder;
        renderAll();
    }
    
    langSelect.value = currentLang;
    langSelect.addEventListener('change', (e) => {
        currentLang = e.target.value;
        localStorage.setItem('lang', currentLang);
        applyTranslations(currentLang);
    });

    // --- ԷՋԵՐԻ ԱՆՑՈՒՄՆԵՐ ---
    function switchPage(activePageId, activeNavEl = null) {
        document.querySelectorAll('.page-section').forEach(section => section.classList.remove('active'));
        document.getElementById(activePageId).classList.add('active');
        
        document.querySelectorAll('.nav-link-item').forEach(link => link.classList.remove('active'));
        if (activeNavEl) activeNavEl.classList.add('active');
    }

    homeNav.addEventListener('click', () => switchPage('homePage', homeNav));
    filmsNav.addEventListener('click', () => switchPage('filmsPage', filmsNav));
    logoLink.addEventListener('click', (e) => { e.preventDefault(); switchPage('homePage', homeNav); });
    adminPageBtn.addEventListener('click', () => switchPage('adminPage'));
    backToHomeBtn.addEventListener('click', () => switchPage('homePage', homeNav));

    // --- ՄՈՒՏՔԻ ՊԱՏՈՒՀԱՆ (LOGIN MODAL) ---
    openModalBtn.addEventListener('click', () => modalOverlay.style.display = 'flex');
    closeModalBtn.addEventListener('click', () => modalOverlay.style.display = 'none');
    modalOverlay.addEventListener('click', (e) => { if(e.target === modalOverlay) modalOverlay.style.display = 'none'; });

    loginForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const emailVal = document.getElementById('email').value;
        const tempName = emailVal.split('@')[0];
        
        if (!users.some(u => u.email.toLowerCase() === emailVal.toLowerCase())) {
            const newUser = { id: Date.now(), username: tempName, email: emailVal };
            users.push(newUser);
            localStorage.setItem('users', JSON.stringify(users));
            renderUsers();
        }

        modalOverlay.style.display = 'none';
        loginForm.reset();
        
        let welcomeMsg = translations[currentLang].welcome_alert.replace('{name}', tempName);
        alert(welcomeMsg);
    });

    // --- ՈՐՈՆՈՒՄ ԵՎ ԺԱՆՐԵՐ ---
    movieSearch.addEventListener('focus', () => genresDropdown.classList.add('show'));
    document.addEventListener('click', (e) => {
        if (!searchContainer.contains(e.target)) {
            genresDropdown.classList.remove('show');
        }
    });

    movieSearch.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
            genresDropdown.classList.remove('show');
            switchPage('filmsPage', filmsNav);
            filterMovies(movieSearch.value, 'all');
        }
    });

    document.querySelectorAll('.genre-badge-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const genreKey = btn.getAttribute('data-genre-key');
            genresDropdown.classList.remove('show');
            switchPage('filmsPage', filmsNav);
            movieSearch.value = ""; 
            filterMovies("", genreKey);
        });
    });

    function filterMovies(searchText, genreKey) {
        let filtered = movies;

        if (genreKey && genreKey !== 'all') {
            filtered = filtered.filter(m => m.genreKey === genreKey);
        }

        if (searchText.trim() !== "") {
            const searchLower = searchText.toLowerCase();
            filtered = filtered.filter(m => {
                const translation = m.translations[currentLang] || m.translations['en'];
                return translation.title.toLowerCase().includes(searchLower) || 
                       translation.shortDesc.toLowerCase().includes(searchLower);
            });
        }

        renderCatalogGrid(filtered);
    }

    // --- ՖԻԼՄԻ ՄԵԾԱՑՎԱԾ ՊԱՏՈՒՀԱՆ (DETAILS MODAL) ---
    function openMovieModal(movie) {
        const trans = movie.translations[currentLang] || movie.translations['en'];
        modalMovieImg.src = movie.img;
        modalMovieImg.alt = trans.title;
        modalMovieTitle.textContent = trans.title;
        modalMovieGenre.textContent = trans.genre;
        modalMovieDesc.textContent = trans.desc;
        
        watchTrailerBtn.href = `https://www.youtube.com/watch?v=${movie.trailerId}`;
        movieModalOverlay.style.display = 'flex';
    }

    closeMovieModalBtn.addEventListener('click', () => movieModalOverlay.style.display = 'none');
    movieModalOverlay.addEventListener('click', (e) => { if(e.target === movieModalOverlay) movieModalOverlay.style.display = 'none'; });

    // --- ԳԵՆԵՐԱՑՈՒՄ (RENDER) ---
    function createMovieCard(movie) {
        const trans = movie.translations[currentLang] || movie.translations['en'];
        const card = document.createElement('div');
        card.className = 'movie-card';
        card.innerHTML = `
            <img class="movie-img" src="${movie.img}" alt="${trans.title}">
            <div class="movie-content">
                <div>
                    <h3>${trans.title}</h3>
                    <span class="genre">${trans.genre}</span>
                    <p>${trans.shortDesc}</p>
                </div>
            </div>
        `;
        card.addEventListener('click', () => openMovieModal(movie));
        return card;
    }

    function renderAll() {
        featuredMoviesGrid.innerHTML = "";
        movies.slice(0, 3).forEach(m => {
            featuredMoviesGrid.appendChild(createMovieCard(m));
        });

        renderCatalogGrid(movies);
        renderUsers();
        renderAdminMovies();
    }

    function renderCatalogGrid(moviesList) {
        moviesCatalogGrid.innerHTML = "";
        if (moviesList.length === 0) {
            noResultsMessage.style.display = 'block';
        } else {
            noResultsMessage.style.display = 'none';
            moviesList.forEach(m => {
                moviesCatalogGrid.appendChild(createMovieCard(m));
            });
        }
    }

    // --- ԱԴՄԻՆԻ ԳՈՐԾՈՂՈՒԹՅՈՒՆՆԵՐ ---
    function renderUsers() {
        usersTableBody.innerHTML = "";
        users.forEach(u => {
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${u.id}</td>
                <td>${u.username}</td>
                <td>${u.email}</td>
                <td><button class="delete-btn" data-id="${u.id}">${translations[currentLang].delete_btn}</button></td>
            `;
            usersTableBody.appendChild(tr);
        });

        document.querySelectorAll('#usersTableBody .delete-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                if (confirm(translations[currentLang].confirm_delete)) {
                    const id = parseInt(e.target.getAttribute('data-id'));
                    users = users.filter(u => u.id !== id);
                    localStorage.setItem('users', JSON.stringify(users));
                    renderUsers();
                }
            });
        });
    }

    function renderAdminMovies() {
        adminMoviesTableBody.innerHTML = "";
        movies.forEach(m => {
            const trans = m.translations[currentLang] || m.translations['en'];
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${m.id}</td>
                <td>${trans.title}</td>
                <td>${trans.genre}</td>
                <td><button class="delete-btn" data-id="${m.id}">${translations[currentLang].delete_btn}</button></td>
            `;
            adminMoviesTableBody.appendChild(tr);
        });

        document.querySelectorAll('#adminMoviesTableBody .delete-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                if (confirm(translations[currentLang].confirm_delete_movie)) {
                    const id = parseInt(e.target.getAttribute('data-id'));
                    movies = movies.filter(m => m.id !== id);
                    localStorage.setItem('movies', JSON.stringify(movies));
                    renderAll();
                }
            });
        });
    }

    addUserForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = document.getElementById('newUsername').value;
        const email = document.getElementById('newUserEmail').value;
        
        const newUser = { id: Date.now(), username: name, email: email };
        users.push(newUser);
        localStorage.setItem('users', JSON.stringify(users));
        
        addUserForm.reset();
        renderUsers();
    });

    addMovieForm.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const genreSelect = document.getElementById('movieGenreKey');
        const selectedGenreText = genreSelect.options[genreSelect.selectedIndex].text;

        const newMovie = {
            id: Date.now(),
            img: document.getElementById('movieImgUrl').value,
            genreKey: genreSelect.value,
            trailerId: document.getElementById('movieTrailerId').value,
            translations: {
                hy: {
                    title: document.getElementById('movieTitleHy').value,
                    genre: selectedGenreText,
                    shortDesc: document.getElementById('movieShortDescHy').value,
                    desc: document.getElementById('movieFullDescHy').value
                },
                en: {
                    title: document.getElementById('movieTitleEn').value,
                    genre: genreSelect.value.toUpperCase(),
                    shortDesc: document.getElementById('movieShortDescEn').value,
                    desc: document.getElementById('movieFullDescEn').value
                },
                ru: {
                    title: document.getElementById('movieTitleRu').value,
                    genre: selectedGenreText,
                    shortDesc: document.getElementById('movieShortDescRu').value,
                    desc: document.getElementById('movieFullDescRu').value
                }
            }
        };

        movies.push(newMovie);
        localStorage.setItem('movies', JSON.stringify(movies));
        
        addMovieForm.reset();
        renderAll();
        alert("Ֆիլմը հաջողությամբ ավելացվեց։");
    });

    // --- ՍԿԶԲՆԱԿԱՆԱՑՈՒՄ ---
    applyTheme(currentTheme);
    applyTranslations(currentLang);
</script>
{% endblock %}
